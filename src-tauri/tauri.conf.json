{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RTX YTDownloader",
  "version": "0.1.0",
  "identifier": "com.rtx.ytdown",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RTX YTDownloader",
        "width": 500,
        "height": 800,
        "minWidth": 500,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "title": "Loading...",
        "width": 400,
        "height": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
      "resources/bins.zip"
    ],
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}